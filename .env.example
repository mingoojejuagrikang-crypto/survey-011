# Copy this to .env.local and fill in.
# Google Cloud Console > APIs & Services > Credentials

# OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origins: http://localhost:5173, https://mingoojejuagrikang-crypto.github.io
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# API Key (for Drive Picker — optional)
# Google Cloud Console > APIs & Services > Credentials > Create API Key
# Restrict to: Google Drive API only
# Without this key, the "Drive ▶" button will not appear.
VITE_GOOGLE_API_KEY=AIza...

# 관리자 공유 폴더 ID (v0.10 멀티유저)
# Google Drive에서 "team-logs" 폴더 생성 후 팀원들에게 Editor 권한으로 공유.
# 각 팀원의 로그 ZIP이 이 폴더 내 {본인이메일}/ 하위 폴더에 자동 업로드됨.
# 폴더 URL의 /folders/뒤 ID를 입력.
VITE_ADMIN_LOGS_FOLDER_ID=123Qag3EJK2R4imt0vfeZwvJyvQ3yL-lw

# 개선요청(feedback) 관리자 수신 폴더 ID (v0.33.0 항목11)
# 개선요청 zip(feedback_<date>_<ts>.zip — 텍스트+스크린샷+경량 로그, 클립 제외)이
# 이 폴더 내 {본인이메일}/ 하위 폴더에 업로드됨. Editor 권한 공유 필요.
# 미설정 시 관리자 업로드는 건너뛰고 사용자 본인 Drive(survey-011/feedback/)에만 저장.
VITE_ADMIN_FEEDBACK_FOLDER_ID=
